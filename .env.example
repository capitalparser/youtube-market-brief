# 01_youtube_market_brief 환경변수
# `cp .env.example .env` 한 뒤 채워서 사용. .env는 gitignored.

# YouTube Data API v3 키. https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Telegram Bot. https://core.telegram.org/bots
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LLM provider 선택: api (OpenAI Chat Completions API) | cli (claude CLI subprocess)
# - api: 어디서나 동작 (cloud cron 포함), OPENAI_API_KEY 필요
# - cli: 로컬에서만 동작, Claude Code 로그인 활용 (별도 키 불필요)
LLM_PROVIDER=api

# OpenAI API (LLM_PROVIDER=api 일 때 사용)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# claude CLI (LLM_PROVIDER=cli 일 때 사용)
CLAUDE_BIN=claude
CLAUDE_MODEL=sonnet
CLAUDE_TIMEOUT_SEC=300

# 자막 백엔드 선택: auto (권장: yt_dlp 후 youtube_transcript_api fallback) | yt_dlp | youtube_transcript_api
TRANSCRIPT_BACKEND=auto
# auto/yt_dlp 사용 시 YouTube 쿠키 파일 경로 (Netscape format, .secrets/ 아래 보관 권장)
YOUTUBE_COOKIE_FILE=
# YouTube 자막/오디오 요청에 사용할 HTTP(S) proxy URL.
# 예: http://USER:PASS@host:port 또는 socks5://USER:PASS@host:port
YOUTUBE_PROXY_URL=

# 자막 엔드포인트가 IP 차단될 때 마지막 fallback: 오디오 다운로드 후 OpenAI STT.
# 비용이 발생하므로 기본값은 false.
ENABLE_STT_FALLBACK=false
STT_MODEL=gpt-4o-mini-transcribe
STT_AUDIO_MAX_MB=24

# Webshare 주거용 프록시 (클라우드 실행 시 YouTube IP 차단 우회)
# https://www.webshare.io — "Residential" 패키지 구매 후 Proxy Username/Password 입력
# 없으면 프록시 없이 실행 (로컬 실행은 보통 불필요)
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=

# Vault override — 미지정 시 walk-up으로 자동 탐지.
# Cloud 실행에선 ./_cloud_vault 같은 임시 디렉토리로 라우팅.
VAULT_ROOT_PATH=

# 동작 옵션
DRY_RUN=false
LOG_LEVEL=INFO
TRANSCRIPT_MAX_CHARS=80000
MAX_VIDEOS_PER_RUN=20
SKIP_SHORTS=true
TIMEZONE=Asia/Seoul
