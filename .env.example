# 01_youtube_market_brief 환경변수
# `cp .env.example .env` 한 뒤 채워서 사용. .env는 gitignored.

# YouTube Data API v3 키. https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Telegram Bot. https://core.telegram.org/bots
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# claude CLI (Claude Code). 사용자 로그인을 활용 — Anthropic API 키 불필요.
CLAUDE_BIN=claude
CLAUDE_MODEL=sonnet
CLAUDE_TIMEOUT_SEC=300

# 동작 옵션
DRY_RUN=false
LOG_LEVEL=INFO
TRANSCRIPT_MAX_CHARS=80000
MAX_VIDEOS_PER_RUN=20
SKIP_SHORTS=true
TIMEZONE=Asia/Seoul
